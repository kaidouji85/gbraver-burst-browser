<div class="{{ROOT_CLASS}}__account-controller">
  <button data-id="login" class="{{loginClassName}}">ログイン</button>
  <div class="{{accountClassName}}">
    <img
      class="{{ROOT_CLASS}}__avatar"
      alt="アカウントのアバター画像"
      data-id="avatar"
    />
    <div class="{{INVISIBLE_ACCOUNT_MENU_CLASS}}" data-id="accountMenu">
      <div class="{{ROOT_CLASS}}__account-name">
        <div class="{{ROOT_CLASS}}__account-name-prefix">アカウント名</div>
        <div class="{{ROOT_CLASS}}__account-name-value">{{accountName}}</div>
      </div>
      <div class="{{ROOT_CLASS}}__account-menu-separation"></div>
      <div
        class="{{ROOT_CLASS}}__delete-account"
        data-id="deleteAccount"
      >アカウント削除</div>
      <div class="{{ROOT_CLASS}}__logout" data-id="logout">ログアウト</div>
    </div>
  </div>
</div>
<div class="{{ROOT_CLASS}}__help">
  <img class="{{helpIconClassName}}" alt="ヘルプアイコン" data-id="helpIcon" />
  <div class="{{INVISIBLE__HELP_MENU_CLASS}}" data-id="helpMenu">
    <a
      class="{{ROOT_CLASS}}__how-to-play"
      href="{{params.howToPlayURL}}"
      target="_blank"
      rel="noopener"
    >遊び方</a>
    <a
      class="{{ROOT_CLASS}}__character-description"
      href="{{params.characterDescriptionURL}}"
      target="_blank"
      rel="noopener"
    >ロボ、パイロット説明</a>
    <div class="{{ROOT_CLASS}}__help-menu-separation"></div>
    <a
      class="{{ROOT_CLASS}}__terms-of-service"
      href="{{params.termsOfServiceURL}}"
      target="_blank"
      rel="noopener"
    >利用規約</a>
    <a
      class="{{ROOT_CLASS}}__privacy-policy"
      href="{{params.privacyPolicyURL}}"
      target="_blank"
      rel="noopener"
    >プライバシーポリシー</a>
    <a
      class="{{ROOT_CLASS}}__contact"
      href="{{params.contactURL}}"
      target="_blank"
      rel="noopener"
    >問い合わせ</a>
  </div>
</div>
<div class="{{ROOT_CLASS}}__armdozers">
  <img
    class="{{ROOT_CLASS}}__gran-dozer"
    alt="グランドーザ"
    src="{{granDozerPath}}"
    data-id="granDozer"
  />
  <img
    class="{{ROOT_CLASS}}__shin-braver"
    alt="シンブレイバー"
    src="{{shinBraverPath}}"
    data-id="shinBraver"
  />
</div>
<div class="{{ROOT_CLASS}}__contents">
  <div class="{{ROOT_CLASS}}__title">
    <img class="{{ROOT_CLASS}}__title-logo" alt="タイトルロゴ" data-id="logo" />
    <small class="{{ROOT_CLASS}}__copy-rights">
      <span class="{{ROOT_CLASS}}__copy-rights-symbol">&copy;</span>
      <span class="{{ROOT_CLASS}}__copy-rights-year">2022</span>
      <span class="{{ROOT_CLASS}}__copy-rights-owner">Pegass85</span>
    </small>
    <small class="{{ROOT_CLASS}}__music">音楽 魔王魂</small>
  </div>
  <div class="{{gameClassName}}">
    <button class="{{ROOT_CLASS}}__config" data-id="config">
      <span
        class="{{ROOT_CLASS}}__menu-button-icon"
        aria-hidden="true"
      >⚙️</span>
      <span class="{{ROOT_CLASS}}__menu-button-label">設定</span>
    </button>
    <button class="{{netBattleClassName}}" data-id="netBattle">
      <span
        class="{{ROOT_CLASS}}__menu-button-icon"
        aria-hidden="true"
      >🌐</span>
      <span class="{{ROOT_CLASS}}__menu-button-label">ネット対戦</span>
    </button>
    <button class="{{ROOT_CLASS}}__arcade" data-id="arcade">
      <span
        class="{{ROOT_CLASS}}__menu-button-icon"
        aria-hidden="true"
      >🕹</span>
      <span class="{{ROOT_CLASS}}__menu-button-label">アーケード</span>
    </button>
    <button class="{{ROOT_CLASS}}__story" data-id="story">
      <span
        class="{{ROOT_CLASS}}__menu-button-icon"
        aria-hidden="true"
      >📖</span>
      <span class="{{ROOT_CLASS}}__menu-button-label">ストーリー</span>
    </button>
    <button class="{{ROOT_CLASS}}__tutorial" data-id="tutorial">
      <span class="{{ROOT_CLASS}}__tutorial-icon" aria-hidden="true">🔰</span>
      <span class="{{ROOT_CLASS}}__tutorial-label">チュートリアル</span>
    </button>
  </div>
</div>